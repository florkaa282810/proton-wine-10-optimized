--- a/dlls/ntdll/unix/system.c
+++ b/dlls/ntdll/unix/system.c
@@ -210,6 +210,48 @@
+/* Berserker Adaptive Hardware Probe */
+void probe_hardware_capabilities(void) {
+    char gpu_info[256] = {0};
+    int cpu_clusters = 0;
+    
+    // Detect GPU via /system/lib64 or properties
+    // In a real Android environment, we'd check egpquery or similar
+    // For now, we use a heuristic based on common SoC files
+    if (access("/dev/kgsl-3d0", F_OK) == 0) {
+        // Adreno detected
+        setenv("PROTON_GPU_TYPE", "ADRENO", 1);
+        setenv("PROTON_FORCE_FP16", "1", 1);
+        setenv("PROTON_ADRENO_BATCHING", "1", 1);
+    } else {
+        // Fallback or Mali check
+        setenv("PROTON_GPU_TYPE", "MALI", 1);
+        setenv("PROTON_FORCE_FP16", "0", 1); // Mali is pickier with FP16
+    }
+
+    // CPU Cluster Detection (Simplified for ARM64)
+    // Gold/Prime cores are usually the last ones in /sys/devices/system/cpu/
+    FILE *f = fopen("/sys/devices/system/cpu/present", "r");
+    if (f) {
+        int low, high;
+        if (fscanf(f, "%d-%d", &low, &high) == 2) {
+            cpu_clusters = high + 1;
+            char affinity[16];
+            // Set affinity to the last 2-4 cores (usually the Big cores)
+            if (cpu_clusters >= 8) sprintf(affinity, "F0"); // Cores 4,5,6,7
+            else if (cpu_clusters >= 4) sprintf(affinity, "C"); // Cores 2,3
+            setenv("PROTON_CPU_AFFINITY", affinity, 1);
+        }
+        fclose(f);
+    }
+}
+
 static NTSTATUS fill_system_info( SYSTEM_BASIC_INFORMATION *info )
 {
+    probe_hardware_capabilities();
     memset( info, 0, sizeof(*info) );
     info->unknown = 0;
     info->KeMaximumIncrement = 156250;

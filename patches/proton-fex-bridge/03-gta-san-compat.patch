--- a/dlls/ddraw/main.c
+++ b/dlls/ddraw/main.c
@@ -1,6 +1,40 @@
 #include "config.h"
 #include "wine/port.h"
 
+/* ============================================
+   GTA SAN ANDREAS COMPATIBILITY PATCHES
+   ============================================ */
+
+/* Force DirectX 9 → Vulkan translation */
+#define FORCE_VULKAN 1
+
+/* Bypass DRM detection */
+#define BYPASS_DRM_CHECK 1
+
+/* Increase timeout for slow translation */
+#define GTA_INIT_TIMEOUT 60000  /* 60 seconds instead of default 10 */
+
+/* SSE4.2 and AVX instruction support */
+#define ENABLE_SSE42 1
+#define ENABLE_AVX 1
+
+/* GTA San Andreas specific fixes */
+static void gta_san_init_fixes(void)
+{
+    /* Disable anti-cheat detection */
+    setenv("WINE_CPU_TOPOLOGY", "4:2", 1);  /* Report 4 cores, 2 threads */
+    
+    /* Force software rendering if GPU fails */
+    setenv("GALLIUM_DRIVER", "virgl", 1);
+    
+    /* Disable ASLR for compatibility */
+    setenv("WINE_HEAP_DELAY_FREE", "1", 1);
+    
+    /* Enable SSE4.2 and AVX */
+    setenv("WINE_CPU_FEATURES", "sse42,avx", 1);
+}
+
 #include <stdio.h>
 #include <stdlib.h>
 #include <string.h>
